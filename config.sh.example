# Đổi tên file này thành config.sh và điền thông tin.
# Hoặc tải ZIP từ trang web — file config.sh đã được nhúng sẵn.
TELEGRAM_TOKEN=""
TELEGRAM_CHAT_ID=""


# Tuỳ chọn — long polling Telegram (mặc định trong service.sh: 50s / curl max 75s)
# TG_POLL_TIMEOUT=50
# TG_CURL_MAX_TIME=75


# Gói AnyDesk (PROJECT_MEDIA).
# ANYDESK_PKG=com.anydesk.anydeskandroid

# Hotspot: khi gõ /hotspot_on không kèm SSID/mật khẩu.
# Có thể gõ: /hotspot_on TênWifi MậtKhẩu (mật khẩu được phép nhiều từ).
# HOTSPOT_SSID="MyHotspot"
# HOTSPOT_PASS="ban_mat_khau"

# SMS mới → tự gửi Telegram (mặc định bật, không cần /sms_watch_on).
# SMS_WATCH_INTERVAL=8
# SMS_WATCH_AUTO=0

